#!/usr/bin/env bash
# Regenerates the Crystal SDK from swagger.yaml using OpenAPI Generator.
# Run from the repo root: bin/generate
#
# Options:
#   SWAGGER_PATH  Path or URL to swagger.yaml (default: ../mailmate-web/swagger/v1/swagger.yaml)
#   GENERATOR_VERSION  openapi-generator-cli version (default: latest)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SWAGGER_PATH="${SWAGGER_PATH:-$REPO_ROOT/../mailmate-web/swagger/v1/swagger.yaml}"

echo "→ Generating Crystal SDK from: $SWAGGER_PATH"

npx --yes @openapitools/openapi-generator-cli generate \
  --input-spec "$SWAGGER_PATH" \
  --generator-name crystal \
  --output "$REPO_ROOT" \
  --additional-properties "gemName=mailmate_api,moduleName=MailMateAPI,gemVersion=0.1.0,gemHomepage=https://github.com/Win-hhm/mailmate-crystal-sdk"

echo "✓ Done. Review changes and commit."
